# CRM base URL (no trailing slash).
# - `npm run dev`: Vite proxies /api/mobile-login → this URL (avoids CORS during local dev).
# - `npm run build`: must be set; baked into the bundle for browser → CRM requests.
# Use https:// in production (mixed http CRM + https PWA causes “Failed to fetch”).
VITE_CRM_URL=https://hearing-hope-crm.vercel.app

# Same Firebase web config as the CRM / mobile app (Firebase Console → Project settings).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
